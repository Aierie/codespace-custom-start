{
  "name": "custom-screen-extension",
  "displayName": "Custom Screen Extension",
  "description": "A VS Code extension that opens a Custom Screen webview when a devcontainer marker file requests it.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:customScreen.show"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "customScreen.show",
        "title": "Show Custom Screen"
      }
    ]
  },
  "files": [
    "dist/**",
    "media/**",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "build": "node build.js",
    "package:vsix": "npm run build && npx @vscode/vsce package --no-dependencies",
    "install:extension": "bash scripts/install-extension.sh",
    "open:custom-screen": "bash scripts/open-custom-screen.sh",
    "start:extension": "bash scripts/start-extension.sh",
    "test:devcontainer": "npx -y @devcontainers/cli up --workspace-folder ."
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.1"
  },
  "license": "MIT"
}
